{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "heaven-beauty-mcp",
      "version": "0.1.0",
      "title": "Heaven Beauty"
    },
    "tools": [
      {
        "name": "list_products",
        "title": "List products",
        "description": "List Heaven Beauty shop products, optionally filtered by category id.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "WooCommerce category id",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "per_page": {
              "description": "Number of products (default 24)",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_product",
        "title": "Get product",
        "description": "Fetch full details for a Heaven Beauty product by its slug.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Product slug, e.g. 'heavenly-tint'"
            }
          },
          "required": [
            "slug"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_categories",
        "title": "List categories",
        "description": "List Heaven Beauty product categories.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "create_order",
        "title": "Create order",
        "description": "Create a Cash-on-Delivery order in Heaven Beauty for the given billing details and line items.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": true
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "billing": {
              "type": "object",
              "properties": {
                "first_name": {
                  "type": "string",
                  "minLength": 1
                },
                "last_name": {
                  "type": "string",
                  "minLength": 1
                },
                "address_1": {
                  "type": "string",
                  "minLength": 1
                },
                "city": {
                  "type": "string",
                  "minLength": 1
                },
                "postcode": {
                  "type": "string"
                },
                "country": {
                  "type": "string",
                  "minLength": 2,
                  "description": "ISO 3166-1 alpha-2 country code"
                },
                "email": {
                  "type": "string",
                  "format": "email",
                  "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
                },
                "phone": {
                  "type": "string",
                  "minLength": 3
                }
              },
              "required": [
                "first_name",
                "last_name",
                "address_1",
                "city",
                "country",
                "email",
                "phone"
              ]
            },
            "line_items": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "product_id": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  },
                  "quantity": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "product_id",
                  "quantity"
                ]
              }
            }
          },
          "required": [
            "billing",
            "line_items"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
